<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="cache-control" content="public">
    <title>ECharts</title>
    <meta http-equiv="refresh" content="-3600">
    <script src="echarts.min.js"></script>
    <script src="echarts-gl.min.js"></script>
  </head>
  <body>
    <div id="main" ></div>
    <script>
      var option = {"series":[{"type":"gauge","startAngle":90,"endAngle":-270,"pointer":{"show":false},"progress":{"show":true,"overlap":false,"roundCap":true,"clip":false,"itemStyle":{"borderWidth":1,"borderColor":"#464646"}},"axisLine":{"lineStyle":{"width":40}},"splitLine":{"show":false,"distance":0,"length":10},"axisTick":{"show":false},"axisLabel":{"show":false,"distance":50},"data":[{"value":20,"name":"Perfect","title":{"offsetCenter":["0%","-30%"]},"detail":{"valueAnimation":true,"offsetCenter":["0%","-20%"]}},{"value":40,"name":"Good","title":{"offsetCenter":["0%","0%"]},"detail":{"valueAnimation":true,"offsetCenter":["0%","10%"]}},{"value":60,"name":"Commonly","title":{"offsetCenter":["0%","30%"]},"detail":{"valueAnimation":true,"offsetCenter":["0%","40%"]}}],"title":{"text":"Demo Chart: Gauge","fontSize":14},"detail":{"width":50,"height":14,"fontSize":14,"color":"inherit","borderColor":"inherit","borderRadius":20,"borderWidth":1,"formatter":"{value}%"}}]};
      // Define used dark mode. Allowed modes: 'default', 'dark', 'auto'
      var myDarkMode = 'default';
      var myChart = echarts.init(document.getElementById('main'),null,{
        width: window.innerWidth-10,
        height: window.innerHeight-20,
      });

      window.addEventListener('resize', function() {
        myChart.resize({
          width: window.innerWidth-10,
          height: window.innerHeight-20,
        });
      });

      const darkModeMediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      function updateDarkMode() {
        // myChart.setTheme() rebuilds the chart from scratch and discards whatever is currently
        // shown (see the bootstrap setOption({}) comment below for why). Save the full current
        // state first and restore it afterward, so this function is safe to call again later —
        // e.g. from the darkModeMediaQuery listener below, when the system's color scheme changes
        // at runtime.
        const currentOption = myChart.getOption();
        // getOption() returns the fully resolved option, including the *previous* theme's own
        // global styling defaults (color palette, background, ...) baked in as explicit values.
        // Delete them before restoring, so they are picked up fresh from the newly applied theme
        // below instead of staying frozen at their old value.
        delete currentOption.color;
        delete currentOption.backgroundColor;
        delete currentOption.gradientColor;
        delete currentOption.textStyle;
        // setTheme() below clears all series before this function restores them again — without
        // this, ECharts treats the restore as brand new series appearing and plays their entrance
        // animation (e.g. bars growing up from zero), which looks like the chart rebuilding instead
        // of just recoloring. Restore without animation, then switch animation back on afterward for
        // any later updates (SSE, user interaction, ...).
        const originalAnimation = currentOption.animation === undefined ? true : currentOption.animation;
        currentOption.animation = false;
        switch (myDarkMode) {
          case 'default':
            myChart.setTheme('default');
            break;
          case 'dark':
            myChart.setTheme('dark');
            break;
          case 'auto':
            const isDarkMode = darkModeMediaQuery.matches;
            myChart.setTheme(isDarkMode ? 'dark' : 'default');
            break;
          default:
            myChart.setTheme('default');
            break;
        }
        myChart.setOption(currentOption);
        myChart.setOption({ animation: originalAnimation });
      }
      darkModeMediaQuery.addEventListener('change', () => {
          updateDarkMode();
      });

      /* preInitFunctions() */

      myChart.setOption({}); // Bootstrap call: creates the chart's internal model so setTheme()
                              // below can take effect (it is a no-op before the first setOption() call).
      updateDarkMode();

      myChart.setOption(option);

      /* userFunctions() */

      // SSE: auto-update chart when source data changes (activated by &sse URL parameter)
      (function() {
        const sseParams = new URLSearchParams(window.location.search);
        if (sseParams.has('sse')) {
          const sseUrl = window.location.pathname.replace('echarts.html', 'events') + window.location.search;
          const dataUrl = window.location.pathname.replace('echarts.html', 'data') + window.location.search;
          const evtSource = new EventSource(sseUrl);
          evtSource.onmessage = () => {
            fetch(dataUrl)
              .then(r => {
                if (!r.ok) throw new Error('flexcharts: /data returned ' + r.status);
                return r.text();
              })
              .then(text => {
                try {
                  myChart.setOption(new Function('return ' + text)());
                } catch(e) {
                  console.error('flexcharts: failed to update chart option', e);
                }
              })
              .catch(e => console.error(e));
          };
        }
      })();

    </script>
  </body>
</html>
