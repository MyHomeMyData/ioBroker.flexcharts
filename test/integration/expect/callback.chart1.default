<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="cache-control" content="public">
    <title>ECharts</title>
    <meta http-equiv="refresh" content="-3600">
    <script src="echarts.min.js"></script>
    <script src="echarts-gl.min.js"></script>
  </head>
  <body>
    <div id="main" ></div>
    <script>
      var option = {"tooltip":{"trigger":"axis"},"legend":{},"xAxis":[{"type":"category","data":["Mon","Tue","Wed","Thu","Fri","Sat","Sun"]}],"yAxis":[{"type":"value"}],"series":[{"name":"Grid","type":"bar","color":"#ff9999","stack":"Supply","data":[8,19,21,50,26,0,36]},{"name":"PV","type":"bar","color":"#ff0000","stack":"Supply","data":[30,32,20,8,33,21,36]},{"name":"Household","type":"bar","color":"#66b3ff","stack":"Consumption","data":[16,12,11,13,14,9,12]},{"name":"Heat pump","type":"bar","color":"#006cd6","stack":"Consumption","data":[22,24,30,20,22,12,25]},{"name":"Wallbox","type":"bar","color":"#0000ff","stack":"Consumption","data":[0,15,0,25,23,0,35]}]};
      // Define used dark mode. Allowed modes: 'default', 'dark', 'auto'
      var myDarkMode = 'default';
      var myChart = echarts.init(document.getElementById('main'),null,{
        width: window.innerWidth-10,
        height: window.innerHeight-20,
      });

      window.addEventListener('resize', function() {
        myChart.resize({
          width: window.innerWidth-10,
          height: window.innerHeight-20,
        });
      });

      const darkModeMediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      function updateDarkMode() {
        switch (myDarkMode) {
          case 'default':
            myChart.setTheme('default');
            break;
          case 'dark':
            myChart.setTheme('dark');
            break;
          case 'auto':
            const isDarkMode = darkModeMediaQuery.matches;
            myChart.setTheme(isDarkMode ? 'dark' : 'default');
            break;
          default:
            myChart.setTheme('default');
            break;
        }
      }
      darkModeMediaQuery.addEventListener('change', () => {
          updateDarkMode();
      });

      myChart.setOption(option);

      /* userFunctions() */

      updateDarkMode();

      // SSE: auto-update chart when source data changes (activated by &sse URL parameter)
      (function() {
        const sseParams = new URLSearchParams(window.location.search);
        if (sseParams.has('sse')) {
          const sseUrl = window.location.pathname.replace('echarts.html', 'events') + window.location.search;
          const dataUrl = window.location.pathname.replace('echarts.html', 'data') + window.location.search;
          const evtSource = new EventSource(sseUrl);
          evtSource.onmessage = () => {
            fetch(dataUrl)
              .then(r => {
                if (!r.ok) throw new Error('flexcharts: /data returned ' + r.status);
                return r.text();
              })
              .then(text => {
                try {
                  myChart.setOption(new Function('return ' + text)());
                } catch(e) {
                  console.error('flexcharts: failed to update chart option', e);
                }
              })
              .catch(e => console.error(e));
          };
        }
      })();

    </script>
  </body>
</html>
